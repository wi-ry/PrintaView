{
  "name": "printaview",
  "version": "1.0.0",
  "description": "Unified Downloads preview app for Windows",
  "main": "src/main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build:icons": "node build-icons.js",
    "prebuild:win": "npm run build:icons",
    "build:win": "electron-builder --win portable -c.win.signAndEditExecutable=false",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "sharp": "^0.35.2"
  },
  "build": {
    "appId": "com.printaview.app",
    "productName": "PrintaView",
    "files": [
      "src/**/*",
      "build/icon.png",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "icon": "build/icon.png",
      "signAndEditExecutable": false,
      "target": [
        "portable"
      ],
      "artifactName": "${productName}-${version}-Portable.${ext}"
    }
  }
}
